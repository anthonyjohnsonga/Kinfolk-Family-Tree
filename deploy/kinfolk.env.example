# Container release to deploy. Do not use "latest" in production.
KINFOLK_VERSION=0.0.2
KINFOLK_PORT=3040

# PostgreSQL settings. Use a long URL-safe password containing letters,
# numbers, underscores, and hyphens.
POSTGRES_DB=kinfolk
POSTGRES_USER=kinfolk
POSTGRES_PASSWORD=replace_with_a_long_random_URL_safe_password

# Absolute host root. Kinfolk uses database/postgres, database/backups,
# and configure/ beneath this directory.
KINFOLK_ROOT_PATH=/srv/kinfolk

# Authentication session settings. Set COOKIE_SECURE=true only with HTTPS.
SESSION_DAYS=7
COOKIE_SECURE=false

# Optional backup settings used with compose.backup.yaml.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
