{
  "name": "@kinfolk/api",
  "private": true,
  "type": "module",
  "exports": {
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./dist/contract.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "db:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "@fastify/cookie": "latest",
    "dotenv": "latest",
    "fastify": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "prisma": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
