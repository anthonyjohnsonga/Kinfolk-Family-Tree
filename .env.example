POSTGRES_DB=kinfolk
POSTGRES_USER=kinfolk
POSTGRES_PASSWORD=replace_with_a_long_random_URL_safe_password
KINFOLK_PORT=8080

# Optional storage and backup settings. Paths must exist before Compose starts.
KINFOLK_DB_PATH=/srv/kinfolk/database
KINFOLK_BACKUP_PATH=/srv/kinfolk/backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30

# Optional direct-NFS backup destination.
KINFOLK_NFS_ADDR=192.0.2.10
KINFOLK_NFS_EXPORT=/exports/kinfolk-backups
